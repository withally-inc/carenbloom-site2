{
  "git": {
    "deploymentEnabled": false
  },
  "functions": {
    "api/applications.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/goods",
      "destination": "/brands",
      "permanent": true
    },
    {
      "source": "/goods/",
      "destination": "/brands/",
      "permanent": true
    },
    {
      "source": "/creators",
      "destination": "/talents",
      "permanent": true
    },
    {
      "source": "/creators/",
      "destination": "/talents/",
      "permanent": true
    }
  ]
}
