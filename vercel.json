{
  "git": {
    "deploymentEnabled": false
  },
  "functions": {
    "api/applications.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    { "source": "/mission", "destination": "/company/", "permanent": true },
    { "source": "/mission/", "destination": "/company/", "permanent": true },
    { "source": "/about", "destination": "/company/", "permanent": true },
    { "source": "/about/", "destination": "/company/", "permanent": true },
    { "source": "/brands", "destination": "/in-market/", "permanent": true },
    { "source": "/brands/", "destination": "/in-market/", "permanent": true },
    { "source": "/goods", "destination": "/in-market/", "permanent": true },
    { "source": "/goods/", "destination": "/in-market/", "permanent": true },
    { "source": "/capital", "destination": "/deals/", "permanent": true },
    { "source": "/capital/", "destination": "/deals/", "permanent": true },
    { "source": "/talents/apply", "destination": "/careers/apply/", "permanent": true },
    { "source": "/talents/apply/", "destination": "/careers/apply/", "permanent": true },
    { "source": "/talents/:path*", "destination": "/careers/:path*", "permanent": true },
    { "source": "/creators", "destination": "/careers/", "permanent": true },
    { "source": "/creators/", "destination": "/careers/", "permanent": true }
